{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "coto-ui-kit": {
      "projectType": "library",
      "root": "projects/coto-ui-kit",
      "sourceRoot": "projects/coto-ui-kit/src",
      "prefix": "coto",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/coto-ui-kit/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/coto-ui-kit/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/coto-ui-kit/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/coto-ui-kit/tsconfig.spec.json"
          }
        }
      }
    }
  }
}
